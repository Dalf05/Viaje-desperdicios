rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - User's unique ID
    //   - displayName: string (required) - User's chosen name
    //
    // Collection: availability
    // Document ID: {userId}
    // Fields:
    //   - userId: string (required) - User's unique ID
    //   - unavailableDates: list of strings (required) - Dates (YYYY-MM-DD) user is NOT available
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'displayName']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50;
    }

    function isValidAvailability(data) {
      return data.keys().hasOnly(['userId', 'unavailableDates']) &&
             data.userId is string && data.userId.size() > 0 &&
             data.unavailableDates is list && data.unavailableDates.size() < 500;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /availability/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidAvailability(request.resource.data);
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
