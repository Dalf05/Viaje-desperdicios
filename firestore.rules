rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - User's unique ID
    //   - displayName: string (required) - User's chosen name
    //   - email: string (required) - User's email
    //   - canVote: boolean (optional) - Whether the user can vote
    //
    // Collection: availability
    // Document ID: {userId}
    // Fields:
    //   - userId: string (required) - User's unique ID
    //   - unavailableDates: list of strings (required) - Dates (YYYY-MM-DD) user is NOT available
    //
    // Collection: destinations
    // Document ID: {userId}
    // Fields:
    //   - userId: string (required) - User's unique ID
    //   - provinceId: string (required) - ID of the selected province
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "danielmolinoferron@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function isValidUser(data) {
      return data.keys().hasAny(['uid', 'displayName', 'email']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             data.email is string && data.email.size() > 0;
    }

    function isValidAvailability(data) {
      return data.keys().hasOnly(['userId', 'unavailableDates']) &&
             data.userId is string && data.userId.size() > 0 &&
             data.unavailableDates is list && data.unavailableDates.size() < 500;
    }

    function isValidDestination(data) {
      return data.keys().hasOnly(['userId', 'provinceId']) &&
             data.userId is string && data.userId.size() > 0 &&
             data.provinceId is string && data.provinceId.size() > 0 && data.provinceId.size() < 50;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && (!('canVote' in request.resource.data) || request.resource.data.canVote == resource.data.canVote)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /availability/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidAvailability(request.resource.data);
      allow delete: if isAdmin();
    }

    match /destinations/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidDestination(request.resource.data);
      allow delete: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
