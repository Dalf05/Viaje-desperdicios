{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "canVote": { "type": "boolean" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "UserAvailability": {
      "title": "User Availability",
      "description": "Dates when a user is NOT available",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "unavailableDates": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["userId", "unavailableDates"]
    },
    "DestinationVote": {
      "title": "Destination Vote",
      "description": "User's preferred destination",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "provinceId": { "type": "string" }
      },
      "required": ["userId", "provinceId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile"
    },
    "/availability/{userId}": {
      "schema": "UserAvailability",
      "description": "User's unavailable dates"
    },
    "/destinations/{userId}": {
      "schema": "DestinationVote",
      "description": "User's preferred destination"
    }
  }
}
